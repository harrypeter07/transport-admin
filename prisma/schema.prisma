datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                     String                @id @default(uuid())
  email                  String                @unique
  password               String                // Hashed
  name                   String
  role                   String                // ADMIN, MANAGER, EMPLOYEE, DRIVER
  isActive               Boolean               @default(true)
  requiresPasswordChange Boolean               @default(true)
  resetToken             String?
  resetTokenExpiry       DateTime?
  employee               Employee?
  cab                    Cab?
  leaves                 LeaveRequest[]        @relation("ApplicantLeaves")
  approvedLeaves         LeaveRequest[]        @relation("ApproverLeaves")
  approvedTimings        TimingChangeRequest[] @relation("ApproverTimings")
  notifications          Notification[]
  notificationSettings   NotificationSettings?
}

model Shift {
  id        String     @id @default(uuid())
  name      String     // e.g. "Morning Shift"
  startTime String     // e.g. "09:00"
  endTime   String     // e.g. "18:00"
  employees Employee[]
  cabs      Cab[]
  routes    Route[]
}

model Cab {
  id            String  @id @default(uuid())
  vehicleNumber String  @unique
  capacity      Int     // e.g. 4, 6
  vendor        String
  status        String  // AVAILABLE, ACTIVE, MAINTENANCE
  userId        String? @unique
  user          User?   @relation(fields: [userId], references: [id])
  driverName    String
  driverPhone   String
  licenseNumber String
  driverAddress String?
  driverX       Float?
  driverY       Float?
  placeId       String?
  formattedAddress String?
  assignedZone    String?
  assignedSubZone String?
  routes        Route[]
  shifts        Shift[]
  rosterStatus  CabRosterStatus[]
  driverAssignments DriverAssignment[]
}

model PickupPoint {
  id           String     @id @default(uuid())
  name         String
  x            Float      // longitude
  y            Float      // latitude
  zone         String     // N/S/E/W
  subZone      String     // NE/NW/SE/SW
  distanceRing String     // NEAR/MID/FAR
  address      String?
  landmark     String?
  employees    Employee[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Employee {
  id           String                @id @default(uuid())
  userId       String?               @unique
  user         User?                 @relation(fields: [userId], references: [id])
  employeeCode String                @unique
  name         String
  gender       String                // MALE, FEMALE
  phone        String
  email        String                @unique
  address      String
  x            Float                 // coordinate X
  y            Float                 // coordinate Y
  placeId      String?
  formattedAddress String?
  zone                  String?
  subZone               String?
  distanceRing          String?
  distanceFromDepotKm   Float?
  pickupPointId         String?
  pickupPoint   PickupPoint?         @relation(fields: [pickupPointId], references: [id])
  department   String
  designation  String?               @default("Engineer") // Manager, Senior Manager, Lead, Engineer, Intern
  managerId    String?
  manager      Employee?             @relation("ManagerSubordinates", fields: [managerId], references: [id])
  subordinates Employee[]            @relation("ManagerSubordinates")
  shiftId      String?
  shift         Shift?                @relation(fields: [shiftId], references: [id])
  status       String                // ACTIVE, INACTIVE
  stops        RouteStop[]
  timeRequests TimingChangeRequest[]
  transportRoster TransportRoster[]
}

model Route {
  id                String      @id @default(uuid())
  cabId             String
  cab               Cab         @relation(fields: [cabId], references: [id])
  date              String      // e.g. "2026-05-27"
  shiftId           String
  shift             Shift       @relation(fields: [shiftId], references: [id])
  isPickup          Boolean     @default(true)
  totalDistance     Float       
  totalDuration     Float       
  status            String      // PLANNED, ASSIGNED, IN_PROGRESS, COMPLETED, CANCELLED
  tripSequence      Int         @default(1)
  routeNumber       Int?
  startedAt         DateTime?
  completedAt       DateTime?
  currentLat        Float?
  currentLng        Float?
  lastLocationAt    DateTime?
  optimizationScore Float       
  optimizationMode  String      @default("FASTEST_TRAVEL") // MAXIMIZE_UTILIZATION, FASTEST_TRAVEL
  zone              String?
  subZone           String?
  updatedAt         DateTime    @updatedAt
  stops             RouteStop[]
  violations        Violation[]
  hasEscort         Boolean     @default(false)
  events            OperationalEvent[]
  locations         VehicleLocation[]
  deviations        RouteDeviation[]
}

model RouteStop {
  id           String               @id @default(uuid())
  routeId      String
  route        Route                @relation(fields: [routeId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  stopOrder    Int                  
  etaMinutes   Int                  
  status            String               // PENDING, REACHED, BOARDED, SKIPPED
  expectedTime      DateTime?
  actualArrivalTime DateTime?
  boardedTime       DateTime?
  driverDelayMins   Int                  @default(0)
  employeeDelayMins Int                  @default(0)
  events            OperationalEvent[]
}

model Violation {
  id       String  @id @default(uuid())
  routeId  String
  route    Route   @relation(fields: [routeId], references: [id], onDelete: Cascade)
  type     String  // FEMALE_FIRST_PICKUP, FEMALE_LAST_DROP, OVERCAPACITY, ISOLATED_FEMALE, ISOLATED_FEMALE_NIGHT
  severity String  // HIGH, MEDIUM
  resolved Boolean @default(false)
  notes    String?
}

model Holiday {
  id          String  @id @default(uuid())
  date        String  @unique // "YYYY-MM-DD"
  name        String
  description String?
}

model LeaveRequest {
  id          String   @id @default(uuid())
  applicantId String
  applicant   User     @relation("ApplicantLeaves", fields: [applicantId], references: [id])
  startDate   String   // "YYYY-MM-DD"
  endDate     String   // "YYYY-MM-DD"
  status      String   // PENDING, APPROVED, REJECTED
  approverId  String?
  approver    User?    @relation("ApproverLeaves", fields: [approverId], references: [id])
  comments    String?
}

model TimingChangeRequest {
  id            String   @id @default(uuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])
  requestType   String   // PICKUP, DROP
  requestedTime String   // e.g. "08:30"
  currentTime   String   // e.g. "09:00"
  status        String   // PENDING, APPROVED, REJECTED
  approverId    String?
  approver      User?    @relation("ApproverTimings", fields: [approverId], references: [id])
  comments      String?
}

model SystemSettings {
  id                           String  @id @default("default")
  leaveApprovalRequired        Boolean @default(true)
  timingChangeApprovalRequired Boolean @default(true)
  // Location & Depot
  defaultCity                  String  @default("Nagpur")
  defaultCountry               String  @default("India")
  defaultDepotLat              Float   @default(21.0625)
  defaultDepotLng              Float   @default(79.0526)
  depotName                    String  @default("MIHAN Depot")
  depotPlaceId                 String?
  depotFormattedAddress        String?
  maxPickupRadiusKm            Int     @default(70)
  // Financial
  currencySymbol               String  @default("₹")
  fuelPricePerLitre            Float   @default(100.0)
  avgFuelMileageKmL            Float   @default(10.0)
  // Route Optimization Constraints
  maxRouteDistanceKm            Int     @default(45)
  maxRouteDurationMin           Int     @default(90)
  maxClusterRadiusKm            Int     @default(15)
  maxEmployeeDetourKm           Int     @default(10)
}

model OperationalEvent {
  id          String    @id @default(uuid())
  type        String    // ROUTE_STARTED, STOP_REACHED, EMPLOYEE_BOARDED, STOP_SKIPPED, ROUTE_COMPLETED
  timestamp   DateTime  @default(now())
  routeId     String?
  route       Route?    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  routeStopId String?
  routeStop   RouteStop? @relation(fields: [routeStopId], references: [id], onDelete: Cascade)
  cabId       String?
  employeeId  String?
  metadata    String?   // JSON string for extra data like delay reasons
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  category  String   // ROUTE, LEAVE, APPROVAL, SYSTEM, OPTIMIZATION
  read      Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())
}

model NotificationSettings {
  id                    String  @id @default(uuid())
  userId                String  @unique
  user                  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  routeNotifications    Boolean @default(true)
  leaveNotifications    Boolean @default(true)
  approvalNotifications Boolean @default(true)
  systemNotifications   Boolean @default(true)
}

model VehicleLocation {
  id        String   @id @default(uuid())
  routeId   String
  route     Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  lat       Float
  lng       Float
  timestamp DateTime @default(now())
}

model RouteDeviation {
  id        String   @id @default(uuid())
  routeId   String
  route     Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  type      String   // OFF_ROUTE, STALLED
  lat       Float
  lng       Float
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model TransportRoster {
  id                  String   @id @default(uuid())
  employeeId          String
  employee            Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date                String   // e.g. "2026-06-16"
  transportRosterStatus String  // PRESENT, NO_SHOW, ON_LEAVE, MEDICAL_LEAVE
  transportRosterDate DateTime @default(now())
  sourceSheet         String?  // e.g. "16-6-26" for tracking which workbook sheet
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([employeeId, date])
  @@index([date])
}

model CabRosterStatus {
  id                String   @id @default(uuid())
  cabId             String
  cab               Cab      @relation(fields: [cabId], references: [id], onDelete: Cascade)
  date              String   // e.g. "2026-06-16"
  cabRosterStatus   String   // ACTIVE, INACTIVE, MAINTENANCE
  activeForDate     DateTime?
  inactiveForDate   DateTime?
  sourceSheet       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([cabId, date])
  @@index([date])
}

model DriverAssignment {
  id                String   @id @default(uuid())
  cabId             String
  cab               Cab      @relation(fields: [cabId], references: [id], onDelete: Cascade)
  driverName        String
  driverPhone       String
  date              String   // e.g. "2026-06-16"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([cabId, date])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  role      String?
  action    String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, OPTIMIZE, PUBLISH
  entity    String   // Employee, Cab, Route, Shift, SystemSettings, Leave, User
  entityId  String?
  before    Json?
  after     Json?
  ip        String?
  createdAt DateTime @default(now())
}

model BaselineRoute {
  id              String   @id @default(uuid())
  snapshotId      String
  date            String   @default("")
  routeData       Json
  markers         Json?
  routeGeometry   Json?
  statistics      Json
  createdAt       DateTime @default(now())

  @@map("baseline_routes")
}

model OptimizedRouteSnapshot {
  id              String   @id @default(uuid())
  optimizationId  String
  date            String   @default("")
  routeData       Json
  markers         Json?
  routeGeometry   Json?
  statistics      Json
  createdAt       DateTime @default(now())

  @@map("optimized_routes")
}

model RouteDistanceCache {
  id          String   @id @default(uuid())
  originX     Float
  originY     Float
  destX       Float
  destY       Float
  distanceKm  Float
  durationMin Float
  createdAt   DateTime @default(now())

  @@unique([originX, originY, destX, destY])
  @@index([originX, originY])
  @@index([destX, destY])
}

model OptimizationRun {
  id            String   @id @default(uuid())
  date          String   // YYYY-MM-DD
  strategy      String   // e.g. "BALANCED", "MAXIMIZE_UTILIZATION", "MINIMIZE_TIME"
  employeeCount Int
  cabCount      Int
  distance      Float
  duration      Float
  metrics       Json     // Store JSON metrics (underfilled, violations, etc.)
  createdAt     DateTime @default(now())

  @@index([date])
}


{
	"name": "next-app",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "cross-env NODE_OPTIONS=--max-old-space-size=1536 next dev --webpack",
		"build": "cross-env NODE_OPTIONS=--max-old-space-size=1536 next build --webpack",
		"start": "cross-env NODE_OPTIONS=--max-old-space-size=1536 next start",
		"lint": "eslint",
		"postinstall": "prisma generate",
		"db:seed": "npx ts-node prisma/seed.ts",
		"db:seed:test": "npx ts-node scripts/seedTestData.ts",
		"verify": "ts-node --transpile-only --skip-project --compiler-options \"{\\\"module\\\":\\\"commonjs\\\",\\\"moduleResolution\\\":\\\"node\\\"}\" scripts/verify-all.ts",
		"test:scenarios": "ts-node -r tsconfig-paths/register --transpile-only --skip-project --compiler-options \"{\\\"module\\\":\\\"commonjs\\\",\\\"moduleResolution\\\":\\\"node\\\"}\" scripts/test-optimization-scenarios.ts",
		"seed:excel": "ts-node --transpile-only --skip-project --compiler-options \"{\\\"module\\\":\\\"commonjs\\\",\\\"moduleResolution\\\":\\\"node\\\"}\" scripts/seed-from-excel.ts",
		"build:scenarios": "ts-node --transpile-only --skip-project --compiler-options \"{\\\"module\\\":\\\"commonjs\\\",\\\"moduleResolution\\\":\\\"node\\\"}\" scripts/build-test-scenarios.ts",
		"seed:12june": "ts-node -r tsconfig-paths/register --transpile-only --skip-project --compiler-options \"{\\\"module\\\":\\\"commonjs\\\",\\\"moduleResolution\\\":\\\"node\\\"}\" scripts/seed-12june.ts",
		"generate:test:excels": "ts-node -r tsconfig-paths/register --transpile-only --skip-project --compiler-options \"{\\\"module\\\":\\\"commonjs\\\",\\\"moduleResolution\\\":\\\"node\\\"}\" scripts/generate-test-excels.ts",
		"analyze:gtpl": "node scripts/analyze-gtpl-sheets.js",
		"parse:gtpl-fixed": "node scripts/parse-gtpl-workbook-fixed.js",
		"debug:apply-flag": "node scripts/debug-apply-flag.js",
		"audit:gtpl": "ts-node --transpile-only --skip-project --compiler-options \"{\\\"module\\\":\\\"commonjs\\\",\\\"moduleResolution\\\":\\\"node\\\"}\" scripts/audit-gtpl-16june.ts",
		"audit:gtpl-corrected": "ts-node --transpile-only --skip-project --compiler-options \"{\\\"module\\\":\\\"commonjs\\\",\\\"moduleResolution\\\":\\\"node\\\"}\" scripts/audit-gtpl-corrected-16june.ts",
		"sync:gtpl": "ts-node --transpile-only --skip-project --compiler-options \"{\\\"module\\\":\\\"commonjs\\\",\\\"moduleResolution\\\":\\\"node\\\"}\" scripts/sync-gtpl-16june.ts",
		"sync:gtpl-fixed": "ts-node --transpile-only --skip-project --compiler-options \"{\\\"module\\\":\\\"commonjs\\\",\\\"moduleResolution\\\":\\\"node\\\"}\" scripts/sync-gtpl-fixed.ts"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@ducanh2912/next-pwa": "^10.2.9",
		"@googlemaps/js-api-loader": "^2.0.2",
		"@prisma/client": "^6.2.1",
		"@types/bcryptjs": "^2.4.6",
		"bcryptjs": "^3.0.3",
		"clsx": "^2.1.1",
		"framer-motion": "^12.40.0",
		"jose": "^6.2.3",
		"lucide-react": "^1.16.0",
		"next": "16.2.6",
		"prisma": "^6.2.1",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"recharts": "^3.8.1",
		"server-only": "^0.0.1",
		"tailwind-merge": "^3.6.0",
		"xlsx": "^0.18.5",
		"zustand": "^5.0.13"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"cross-env": "^10.1.0",
		"eslint": "^9",
		"eslint-config-next": "16.2.6",
		"tailwindcss": "^4",
		"ts-node": "^10.9.2",
		"typescript": "^5"
	},
	"prisma": {
		"seed": "npx ts-node prisma/seed.ts"
	}
}
